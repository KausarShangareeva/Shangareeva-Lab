PORT=3001

# ── Режим 1: Twilio (реальная отправка на номер владельца) ──────────────────
# Зарегистрируйтесь на https://www.twilio.com/ и подключите WhatsApp Sandbox
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# OWNER_WHATSAPP=whatsapp:+77001234567

# ── Режим 2: wa.me ссылка (проще, без регистрации) ──────────────────────────
# Номер владельца без + и пробелов (код страны + номер)
OWNER_WHATSAPP_NUMBER=77001234567
